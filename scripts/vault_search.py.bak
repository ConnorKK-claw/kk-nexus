#!/usr/bin/env python3
"""
vault_search.py — vault Markdown 全文搜索工具
兼容 obsidian-cli search 接口，基于 Select-String

用法:
    python vault_search.py <vault_path> <keyword>
    python vault_search.py --vault <vault_path> search <keyword>
"""

import sys
import os
import re
from pathlib import Path


def search_vault(vault_path: str, keyword: str) -> list:
    """Search all .md files in vault for keyword."""
    vault = Path(vault_path)
    if not vault.exists():
        print(f"[ERR] Vault not found: {vault_path}")
        return []

    results = []
    for md_file in vault.rglob("*.md"):
        # Skip .gitkeep and files in .obsidian/
        if md_file.name == ".gitkeep":
            continue
        if ".obsidian" in str(md_file):
            continue

        rel = md_file.relative_to(vault)
        try:
            with open(md_file, "r", encoding="utf-8") as f:
                for i, line in enumerate(f, 1):
                    if keyword.lower() in line.lower():
                        snippet = line.strip()[:120]
                        results.append((str(rel), i, snippet))
        except Exception:
            pass

    return results


def main():
    args = sys.argv[1:]
    
    # Parse various invocations
    vault_path = None
    keyword = None
    
    i = 0
    while i < len(args):
        if args[i] == "--vault" and i + 1 < len(args):
            vault_path = args[i + 1]
            i += 2
        elif args[i] == "search" and i + 1 < len(args):
            keyword = args[i + 1]
            i += 2
        elif args[i] == "--help" or args[i] == "-h":
            print(__doc__)
            return
        else:
            if vault_path is None:
                vault_path = args[i]
            elif keyword is None:
                keyword = args[i]
            i += 1

    search_dir = vault_path or os.environ.get("OBSIDIAN_VAULT")
    
    if not search_dir or not keyword:
        print("用法: vault_search.py <vault_path> <keyword>")
        print("  或: vault_search.py --vault <path> search <keyword>")
        sys.exit(1)

    results = search_vault(search_dir, keyword)
    
    if not results:
        print(f"[INFO] 未找到包含「{keyword}」的文件")
        return

    print(f"[OK] 找到 {len(results)} 条匹配：「{keyword}」")
    print()
    
    # Group by file
    from collections import defaultdict
    by_file = defaultdict(list)
    for rel, line_num, snippet in results:
        by_file[rel].append((line_num, snippet))
    
    for file_path in sorted(by_file.keys()):
        lines = by_file[file_path]
        print(f"# {file_path} ({len(lines)} hits)")
        for line_num, snippet in lines[:5]:  # Max 5 lines per file
            # Highlight keyword
            highlighted = snippet.replace(keyword, f">>{keyword}<<")
            print(f"   L{line_num}: {highlighted}")
        if len(lines) > 5:
            print(f"   ... and {len(lines) - 5} more matches")
        print()


if __name__ == "__main__":
    main()
